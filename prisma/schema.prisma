generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  WORKER
  ADMIN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  SELECTED
  REJECTED
  WITHDRAWN
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id           String   @id @default(cuid())
  role         UserRole @default(CUSTOMER)
  name         String
  email        String   @unique
  phoneNumber  String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workerProfile   WorkerProfile?
  customerProfile CustomerProfile?
  reviewsGiven    Review[]         @relation("ReviewsGiven")
  reviewsReceived Review[]         @relation("ReviewsReceived")
  jobsPosted      Job[]
  applications    JobApplication[]
  verificationRequests VerificationRequest[]
}

model WorkerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  bio                String?
  area               String?
  servicesOffered    String[]
  profilePhotoUrl    String?
  trustedBadge       Boolean            @default(false)
  verificationStatus VerificationStatus @default(NONE)
  averageRating      Float              @default(0)
  jobsCompleted      Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  defaultArea String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
  icon String?

  jobs Job[]
}

model Job {
  id            String       @id @default(cuid())
  customerId    String
  title         String
  description   String
  categoryId    String
  area          String
  budget        Float?
  preferredDate DateTime?
  urgency       UrgencyLevel @default(MEDIUM)
  status        JobStatus    @default(OPEN)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  customer     User             @relation(fields: [customerId], references: [id])
  category     Category         @relation(fields: [categoryId], references: [id])
  applications JobApplication[]
  review       Review?
}

model JobApplication {
  id        String            @id @default(cuid())
  jobId     String
  workerId  String
  message   String
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker User @relation(fields: [workerId], references: [id])

  @@unique([jobId, workerId])
}

model VerificationRequest {
  id            String             @id @default(cuid())
  workerId      String
  idDocumentUrl String?
  status        VerificationStatus @default(PENDING)
  submittedAt   DateTime           @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  worker User @relation(fields: [workerId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  jobId      String   @unique
  customerId String
  workerId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  job      Job  @relation(fields: [jobId], references: [id])
  customer User @relation("ReviewsGiven", fields: [customerId], references: [id])
  worker   User @relation("ReviewsReceived", fields: [workerId], references: [id])
}
